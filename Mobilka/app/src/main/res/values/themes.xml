<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.DriveAndAlive" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_yellow</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="Theme.DriveAndAlive.Fullscreen" parent="Theme.DriveAndAlive">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.DriveAndAlive.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_orange</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.DriveAndAlive.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DriveAndAlive.ProgressBar.Stat" parent="Widget.Material3.LinearProgressIndicator">
        <item name="android:layout_height">10dp</item>
        <item name="trackCornerRadius">5dp</item>
        <item name="trackColor">@color/bg_dark</item>
    </style>

</resources>