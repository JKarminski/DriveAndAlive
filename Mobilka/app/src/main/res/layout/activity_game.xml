<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.example.driveandalive.ui.game.GameView
        android:id="@+id/game_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controls_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/controls_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="btn_gas,btn_reverse,btn_nitro"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reverse"
        android:layout_width="140dp"
        android:layout_height="80dp"
        android:text="◀ WSTECZ"
        android:textStyle="bold"
        android:textSize="16sp"
        app:backgroundTint="@color/bg_card_elevated"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/gear_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_gear_down"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="▼"
            android:textSize="20sp"
            app:backgroundTint="@color/bg_card"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_gear_up"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="▲"
            android:textSize="20sp"
            app:backgroundTint="@color/bg_card" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_nitro"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="🚀"
        android:textSize="28sp"
        app:backgroundTint="@color/accent_orange"
        app:layout_constraintBottom_toTopOf="@id/gear_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_gas"
        android:layout_width="160dp"
        android:layout_height="90dp"
        android:text="GAZ ▶"
        android:textStyle="bold"
        android:textSize="18sp"
        app:backgroundTint="@color/accent_orange"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
